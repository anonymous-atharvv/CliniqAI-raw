# CliniQAI Environment Configuration
# Copy to .env and fill in real values
# NEVER commit .env to version control
# In production: use AWS Secrets Manager or HashiCorp Vault

# ─── APPLICATION ─────────────────────────────────────────────
APP_NAME=CliniQAI
ENVIRONMENT=development            # development|staging|production
DEBUG=true                         # Set false in production
APP_VERSION=1.0.0

# ─── HOSPITAL CONFIG ─────────────────────────────────────────
HOSPITAL_NAME="St. Mary Community Hospital"
HOSPITAL_ID=hospital_dev_001
HOSPITAL_EHR_SYSTEM=epic           # epic|cerner|meditech
HOSPITAL_BED_COUNT=300

# ─── DATABASE (PostgreSQL + TimescaleDB) ─────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cliniqai
POSTGRES_USER=cliniqai_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS

# ─── REDIS ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_AGENT_TTL=86400              # 24 hours

# ─── KAFKA ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # In production: SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_USERNAME=cliniqai_kafka
KAFKA_PASSWORD=CHANGE_ME_KAFKA_PASSWORD

# ─── AWS ──────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_WARM_BUCKET=cliniqai-warm-HOSPITAL_ID
S3_ARCHIVE_BUCKET=cliniqai-archive-HOSPITAL_ID
AUDIT_LOG_BUCKET=cliniqai-audit-worm-HOSPITAL_ID
KMS_KEY_ARN=arn:aws:kms:ap-south-1:ACCOUNT:key/KEY_ID

# ─── QDRANT (Vector Store) ────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=patient_embeddings

# ─── ORTHANC (DICOM) ─────────────────────────────────────────
ORTHANC_URL=http://localhost:8042
ORTHANC_USER=orthanc
ORTHANC_PASSWORD=CHANGE_ME_ORTHANC_PASSWORD

# ─── AI MODELS ───────────────────────────────────────────────
# Azure OpenAI (HIPAA BAA available — REQUIRED for production)
LLM_PROVIDER=azure_openai
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=CHANGE_ME
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-02-01

# Anthropic (alternative)
# LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Model paths (mounted volume in Docker)
MONAI_MODEL_PATH=/models/biovil-t
MEDSAM_MODEL_PATH=/models/medsam
TFT_MODEL_PATH=/models/tft-vitals

# ─── SECURITY ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256                # Use RS256 in production
FERNET_KEY=CHANGE_ME_GENERATE_FERNET_KEY  # from cryptography.fernet import Fernet; Fernet.generate_key()

# De-identification salt (MUST be unique per deployment, NEVER reuse)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
DEIDENT_SALT=CHANGE_ME_GENERATE_32_CHAR_RANDOM_STRING

# HashiCorp Vault (for MPI original↔pseudonym mapping)
MPI_VAULT_URL=http://localhost:8200
MPI_VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN

# ─── ALLOWED ORIGINS ─────────────────────────────────────────
# In production: replace with actual hospital domain
ALLOWED_ORIGINS=["http://localhost:3000","https://smary.cliniqai.com"]

# ─── MONITORING ───────────────────────────────────────────────
SENTRY_DSN=https://your-dsn@sentry.io/project
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ─── FEATURE FLAGS ───────────────────────────────────────────
FEATURE_IMAGING_AI=true
FEATURE_SEPSIS_PREDICTION=true
FEATURE_PHARMACIST_AGENT=true
FEATURE_FEDERATED_LEARNING=false   # Enable at 3+ hospitals
FEATURE_VOICE_DOCUMENTATION=false  # Phase 2

# ─── HIPAA ────────────────────────────────────────────────────
HIPAA_COVERED_ENTITY_NAME="St. Mary Community Hospital"

# ─── DEV ONLY (remove in production) ─────────────────────────
DEV_SKIP_AUTH=false                # NEVER true in production
DEV_MOCK_AI=false                  # Use mock AI models (no API calls)
