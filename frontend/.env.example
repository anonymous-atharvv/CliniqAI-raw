# ─────────────────────────────────────────────────────────
# CliniQAI Frontend Environment Variables
# Copy to .env.local for development, set in Netlify UI for production
# ─────────────────────────────────────────────────────────

# Backend API URL
# Local dev: http://localhost:8000
# Railway:   https://cliniqai-backend.up.railway.app
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL (wss:// in production)
# Local dev: ws://localhost:8000
# Railway:   wss://cliniqai-backend.up.railway.app
VITE_WS_URL=ws://localhost:8000

# Hospital identifier (shown in UI)
VITE_HOSPITAL_NAME=CliniQAI Demo Hospital
VITE_HOSPITAL_ID=demo_hospital_001

# Feature flags (match backend FEATURE_* settings)
VITE_FEATURE_IMAGING_AI=true
VITE_FEATURE_SEPSIS_PREDICTION=true
VITE_FEATURE_PHARMACIST_AGENT=true

# App version (injected by CI/CD)
VITE_APP_VERSION=1.0.0
